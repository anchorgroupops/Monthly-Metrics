# Anchor Group Monthly Metrics — environment configuration.
#
# Copy this file to .env and fill in the empty values:
#   cp .env.example .env && chmod 600 .env
#
# scripts/install.sh will auto-generate FLASK_SECRET_KEY and ADMIN_PASSWORD
# on first run if those lines are still empty.

# === REQUIRED ===

# Anthropic API key for monthly KPI research.
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Dashboard login password. Auto-generated by scripts/install.sh if empty.
ADMIN_PASSWORD=

# Flask session signing key. Auto-generated by scripts/install.sh if empty.
FLASK_SECRET_KEY=

# === SMTP (for sending approved emails) ===

# Gmail example: use an App Password (not your normal password).
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=reports@anchorgroup.com
SMTP_PASSWORD=
EMAIL_FROM=reports@anchorgroup.com

# === OPTIONAL ===

# Use the project venv when running heartbeat.sh.
PYTHON=/opt/Monthly-Metrics/.venv/bin/python

# Live FUB pull (only if you want to fetch metrics from the API directly).
# FUB_API_KEY=
