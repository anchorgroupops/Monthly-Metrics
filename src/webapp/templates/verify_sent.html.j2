{% extends "base.html.j2" %}
{% block title %}Check your email — The Anchor Group{% endblock %}
{% block content %}
<div class="card" style="max-width:440px;margin:80px auto;text-align:center;">
  <h1 style="font-size:22px;color:{{ brand.color_primary }};margin-bottom:12px;">
    Check your inbox
  </h1>
  <p style="font-size:14px;line-height:1.55;opacity:0.8;">
    If <strong>{{ email }}</strong> is on the team roster, a sign-in link is on
    its way. The link expires in 15 minutes and works once.
  </p>
  <p style="margin-top:20px;font-size:12px;opacity:0.5;">
    No email after a minute? Check spam, then try again.
  </p>
</div>
{% endblock %}
