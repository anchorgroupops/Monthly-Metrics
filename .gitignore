# Output (local preview only — never commit)
output/
logs/

# SQLite history (admin-uploaded data — never commit)
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# Threshold backups
config/thresholds.json.bak

# Environment & secrets
.env
config/secrets.py

# Local roster file used by the agent portal (sensitive; populate at runtime).
config/agents.csv

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/

# OS
.DS_Store
Thumbs.db

# Coverage artifacts
.coverage
coverage.xml
htmlcov/

# Repo backup bundles (kept out-of-tree)
data/backups/*.bundle

# Notifier dedup marker (operational state, not source)
data/.last-alert

# Stray git scratch file
COMMIT_EDITMSG
