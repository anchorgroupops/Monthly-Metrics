<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>{{ agent.period }} Performance Report — The Anchor Group</title>
  <!--
    Inline CSS only — external stylesheets are stripped by most email clients.
    Table-based layout for maximum Outlook / Gmail compatibility.
    Brand colors/fonts injected from config/settings.py BRAND dict.
  -->
  <style>
    /* Reset */
    body, table, td, p, a { margin: 0; padding: 0; border: 0; }
    img { border: 0; display: block; }
    /* Responsive */
    @media only screen and (max-width: 600px) {
      .email-wrapper { width: 100% !important; }
      .gauge-cell { display: block !important; width: 100% !important; text-align: center !important; padding: 8px 0 !important; }
      .hero-section td { padding: 12px 16px !important; }
    }
  </style>
</head>
<body style="margin:0; padding:0; background-color:{{ brand.color_bg }}; font-family:{{ brand.font_body }};">

<!-- Preheader (hidden preview text in inbox) -->
<div style="display:none; max-height:0; overflow:hidden; font-size:1px; color:{{ brand.color_bg }};">
  {{ agent.period }} — Your Zillow Preferred performance at a glance, {{ agent.name.split()[0] }}.&nbsp;
  {%- for i in range(80) %}&zwnj;&nbsp;{%- endfor %}
</div>

<!-- Outer wrapper -->
<table width="100%" cellpadding="0" cellspacing="0" border="0"
       style="background-color:{{ brand.color_bg }};">
  <tr>
    <td align="center" style="padding: 24px 12px;">

      <!-- Email card -->
      <table class="email-wrapper" width="580" cellpadding="0" cellspacing="0" border="0"
             style="background-color:#FFFFFF; border-radius:12px;
                    box-shadow:0 2px 12px rgba(0,0,0,0.08); overflow:hidden;">

        <!-- ── HEADER ─────────────────────────────────────────────────── -->
        <tr>
          <td style="background-color:{{ brand.color_primary }};
                     padding:24px 32px; text-align:center;">
            {%- if brand.logo_url %}
            <img src="{{ brand.logo_url }}" alt="The Anchor Group"
                 height="48" style="margin:0 auto 12px;" />
            {%- else %}
            <p style="font-family:{{ brand.font_heading }};
                      font-size:22px; font-weight:{{ brand.font_heading_weight_title }}; color:#FFFFFF;
                      letter-spacing:1.5px; text-transform:uppercase; margin:0 0 4px;">
              The Anchor Team
            </p>
            {%- endif %}
            <p style="font-family:{{ brand.font_body }};
                      font-size:13px; color:rgba(255,255,255,0.75);
                      margin:0; letter-spacing:0.3px;">
              Dolphins, Not Sharks &nbsp;·&nbsp; {{ agent.period }} Performance Report
            </p>
          </td>
        </tr>

        <!-- ── GREETING ──────────────────────────────────────────────── -->
        <tr>
          <td style="padding:28px 32px 8px; text-align:left;">
            <p style="font-family:{{ brand.font_heading }};
                      font-size:20px; font-weight:{{ brand.font_heading_weight_title }};
                      color:{{ brand.color_primary }}; margin:0 0 6px; letter-spacing:0.3px;">
              Hi {{ agent.name.split()[0] }},
            </p>
            <p style="font-family:{{ brand.font_body }};
                      font-size:14px; font-weight:{{ brand.font_body_weight_body }};
                      color:{{ brand.color_text }};
                      line-height:1.6; margin:0;">
              Here's your Zillow Preferred snapshot for {{ agent.period }}.
            </p>
          </td>
        </tr>

        <!-- ── OVERALL STATUS BADGE ──────────────────────────────────── -->
        <tr>
          <td style="padding:12px 32px 0;">
            {%- set badge_colors = {
              'Preferred':         {'bg': brand.color_green,  'text': '#FFFFFF'},
              'At Risk':           {'bg': brand.color_yellow, 'text': '#1C2B3A'},
              'Needs Improvement': {'bg': brand.color_red,    'text': '#FFFFFF'},
              'No Data':           {'bg': '#CCCCCC',           'text': '#1C2B3A'}
            } -%}
            {%- set badge = badge_colors.get(agent.overall_status, badge_colors['No Data']) -%}
            <table cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="background-color:{{ badge.bg }};
                           color:{{ badge.text }};
                           font-family:{{ brand.font_body }};
                           font-size:13px; font-weight:700;
                           padding:5px 14px; border-radius:20px;
                           letter-spacing:0.4px;">
                  {%- if agent.overall_status == 'Preferred' %}&#10003; Zillow Preferred
                  {%- elif agent.overall_status == 'At Risk' %}&#9888; At Risk
                  {%- elif agent.overall_status == 'Needs Improvement' %}&#9888; Needs Improvement
                  {%- else %}No Data Available
                  {%- endif %}
                </td>
              </tr>
            </table>
          </td>
        </tr>

        {%- set hero = agent.metrics_list | selectattr('gauge_size', 'equalto', 'hero') | list | first %}
        {%- set secondaries = agent.metrics_list | rejectattr('gauge_size', 'equalto', 'hero') | list %}

        <!-- ── HERO GAUGE ────────────────────────────────────────────── -->
        {%- if hero %}
        <tr>
          <td class="hero-section"
              style="padding:24px 32px 16px; text-align:center;">
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td align="center"
                    style="background-color:{{ brand.color_bg }};
                           border-radius:10px; padding:20px 16px 12px;">
                  {{ gauges[hero.key] }}
                  <p style="font-family:{{ brand.font_body }};
                             font-size:11px; color:{{ brand.color_text }};
                             opacity:0.6; margin:4px 0 0;
                             letter-spacing:0.2px;">
                    Target:
                    {%- if hero.target is not none %}
                      {%- if hero.unit == 'percent' %} {{ "%.1f"|format(hero.target * 100) }}%
                      {%- elif hero.unit == 'seconds' %} under {{ hero.target|int }}s
                      {%- elif hero.unit == 'score' %} {{ hero.target }}
                      {%- else %} {{ hero.target }}{%- endif %}
                    {%- else %} TBD{%- endif %}
                  </p>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        {%- endif %}

        <!-- ── SECONDARY GAUGES ROW ──────────────────────────────────── -->
        {%- if secondaries %}
        <tr>
          <td style="padding:0 32px 24px;">
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                {%- for m in secondaries %}
                <td class="gauge-cell"
                    align="center"
                    style="padding:12px 6px;
                           background-color:{{ brand.color_bg }};
                           border-radius:8px;">
                  {{ gauges[m.key] }}
                  <p style="font-family:{{ brand.font_body }};
                             font-size:10px; color:{{ brand.color_text }};
                             opacity:0.55; margin:3px 0 0;">
                    Target:
                    {%- if m.target is not none %}
                      {%- if m.unit == 'percent' %} {{ "%.0f"|format(m.target * 100) }}%
                      {%- elif m.unit == 'seconds' %} <{{ m.target|int }}s
                      {%- else %} {{ m.target }}{%- endif %}
                    {%- else %} TBD{%- endif %}
                  </p>
                </td>
                {%- if not loop.last %}
                <td width="8px"></td>
                {%- endif %}
                {%- endfor %}
              </tr>
            </table>
          </td>
        </tr>
        {%- endif %}

        <!-- ── OPERATIONAL READINESS ──────────────────────────────────── -->
        {%- if agent.operational_readiness is not none %}
        <tr>
          <td style="padding:0 32px 16px;">
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td align="center"
                    style="padding:14px 12px;
                           background-color:{{ brand.color_primary }};
                           color:#FFFFFF;
                           border-radius:8px;">
                  <span style="font-family:{{ brand.font_body }};
                               font-size:11px; opacity:0.8;
                               letter-spacing:1.2px; text-transform:uppercase;">
                    Operational Readiness
                  </span>
                  <span style="font-family:{{ brand.font_heading }};
                               font-size:22px; font-weight:700;
                               margin-left:12px;">
                    {{ agent.operational_readiness }}
                  </span>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        {%- endif %}

        <!-- ── DIVIDER ───────────────────────────────────────────────── -->
        <tr>
          <td style="padding:0 32px;">
            <hr style="border:none; border-top:1px solid #E8ECEF; margin:0;">
          </td>
        </tr>

        <!-- ── FOOTER ────────────────────────────────────────────────── -->
        <tr>
          <td style="padding:20px 32px 28px; text-align:center;">
            <p style="font-family:{{ brand.font_body }};
                      font-size:13px; font-style:italic;
                      color:{{ brand.color_secondary }};
                      line-height:1.6; margin:0 0 16px;">
              "{{ brand.footer_message }}"
            </p>
            <p style="font-family:{{ brand.font_body }};
                      font-size:11px; color:{{ brand.color_text }};
                      opacity:0.45; margin:0;">
              The Anchor Group &nbsp;·&nbsp; {{ agent.period }}
              &nbsp;·&nbsp; Zillow Preferred Performance
            </p>
          </td>
        </tr>

      </table>
      <!-- /email card -->

    </td>
  </tr>
</table>

</body>
</html>
